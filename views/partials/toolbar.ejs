<!-- Google Translate Script - USING HTTPS -->
<script type="text/javascript">
    function removeGoogleTranslatePopup() {
        setTimeout(function() {
            var banner = document.querySelector('.goog-te-banner-frame');
            if (banner && banner.style) {
                banner.style.display = 'none';
                banner.style.visibility = 'hidden';
                banner.style.height = '0';
            }
            
            var balloon = document.querySelector('.goog-te-balloon-frame');
            if (balloon && balloon.style) {
                balloon.style.display = 'none';
                balloon.style.visibility = 'hidden';
            }
            
            document.body.style.top = '0px';
            document.body.style.position = 'static';
            
            var iframes = document.querySelectorAll('iframe.goog-te-banner-frame');
            iframes.forEach(function(iframe) {
                iframe.style.display = 'none';
                iframe.style.visibility = 'hidden';
            });
        }, 100);
    }
    
    function googleTranslateElementInit() {
        new google.translate.TranslateElement({
            pageLanguage: 'en',
            includedLanguages: 'en,es,fr,de,it,pt,zh-CN,ja,ko,ar,hi,ru,nl,sv,pl,tr,vi,th,ha,ig,yo',
            layout: google.translate.TranslateElement.InlineLayout.HORIZONTAL,
            autoDisplay: false,
            multilanguagePage: true
        }, 'google_translate_element');
        
        setTimeout(removeGoogleTranslatePopup, 200);
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            removeGoogleTranslatePopup();
        });
    } else {
        removeGoogleTranslatePopup();
    }
    
    window.addEventListener('load', function() {
        removeGoogleTranslatePopup();
        
        var observer = new MutationObserver(function(mutations) {
            removeGoogleTranslatePopup();
        });
        
        observer.observe(document.body, {
            childList: true,
            subtree: true
        });
    });
</script>

<!-- CRITICAL: Use HTTPS instead of HTTP -->
<script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" async defer></script>
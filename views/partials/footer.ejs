<script>
// ============================================
// COMPLETE AI CHAT WITH VOICE TO TEXT & TEXT TO VOICE
// ============================================

(function() {
    // DOM Elements
    const chatButton = document.getElementById('aiChatButton');
    const chatModal = document.getElementById('aiChatModal');
    const closeChat = document.getElementById('closeChat');
    const sendButton = document.getElementById('sendMessage');
    const chatInput = document.getElementById('chatInput');
    const chatMessages = document.getElementById('chatMessages');
    const notificationBadge = document.getElementById('notificationBadge');
    const voiceBtn = document.getElementById('voiceBtn');
    const voiceToggleBtn = document.getElementById('voiceToggleBtn');
    const voiceSettingsModal = document.getElementById('voiceSettingsModal');
    const closeSettingsBtn = document.getElementById('closeSettingsBtn');
    const testVoiceBtn = document.getElementById('testVoiceBtn');
    
    let isTyping = false;
    let sessionId = localStorage.getItem('chatSessionId');
    if (!sessionId) {
        sessionId = 'session_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
        localStorage.setItem('chatSessionId', sessionId);
    }
    
    // Voice Settings
    let voiceSettings = {
        language: 'en-US',
        style: 'african',
        speed: 1,
        pitch: 1,
        autoRead: true,
        playAfricanTune: true
    };
    
    let recognition = null;
    let isListening = false;
    let audioContext = null;
    
    // Load saved voice settings
    function loadVoiceSettings() {
        const saved = localStorage.getItem('voiceSettings');
        if (saved) {
            voiceSettings = JSON.parse(saved);
            const langSelect = document.getElementById('voiceLanguage');
            const styleSelect = document.getElementById('voiceStyle');
            const speedInput = document.getElementById('voiceSpeed');
            const pitchInput = document.getElementById('voicePitch');
            const autoReadCheck = document.getElementById('autoReadResponse');
            const tuneCheck = document.getElementById('playAfricanTune');
            if (langSelect) langSelect.value = voiceSettings.language;
            if (styleSelect) styleSelect.value = voiceSettings.style;
            if (speedInput) speedInput.value = voiceSettings.speed;
            if (pitchInput) pitchInput.value = voiceSettings.pitch;
            if (autoReadCheck) autoReadCheck.checked = voiceSettings.autoRead;
            if (tuneCheck) tuneCheck.checked = voiceSettings.playAfricanTune;
            updateSpeedDisplay();
            updatePitchDisplay();
        }
    }
    
    function saveVoiceSettings() {
        localStorage.setItem('voiceSettings', JSON.stringify(voiceSettings));
        if (recognition) recognition.lang = voiceSettings.language;
    }
    
    function updateSpeedDisplay() {
        const speedVal = document.getElementById('voiceSpeed');
        if (speedVal) {
            const val = parseFloat(speedVal.value);
            const text = val < 0.8 ? 'Slow' : (val > 1.2 ? 'Fast' : 'Normal');
            document.getElementById('speedValue').textContent = text;
        }
    }
    
    function updatePitchDisplay() {
        const pitchVal = document.getElementById('voicePitch');
        if (pitchVal) {
            const val = parseFloat(pitchVal.value);
            const text = val < 0.8 ? 'Low' : (val > 1.2 ? 'High' : 'Normal');
            document.getElementById('pitchValue').textContent = text;
        }
    }
    
    // Play African Tune
    function playAfricanTune() {
        if (!voiceSettings.playAfricanTune) return Promise.resolve();
        try {
            if (!audioContext) audioContext = new (window.AudioContext || window.webkitAudioContext)();
            const now = audioContext.currentTime;
            const notes = [220, 261.63, 293.66, 261.63, 220, 196, 220];
            const durations = [0.2, 0.2, 0.3, 0.2, 0.2, 0.3, 0.5];
            notes.forEach((freq, i) => {
                const osc = audioContext.createOscillator();
                osc.type = 'sine';
                osc.frequency.value = freq;
                const oscGain = audioContext.createGain();
                oscGain.gain.setValueAtTime(0.15, now + durations.slice(0,i).reduce((a,b)=>a+b,0));
                oscGain.gain.exponentialRampToValueAtTime(0.0001, now + durations.slice(0,i+1).reduce((a,b)=>a+b,0));
                osc.connect(oscGain);
                oscGain.connect(audioContext.destination);
                osc.start(now + durations.slice(0,i).reduce((a,b)=>a+b,0));
                osc.stop(now + durations.slice(0,i+1).reduce((a,b)=>a+b,0));
            });
            return new Promise(resolve => setTimeout(resolve, 400));
        } catch(e) { return Promise.resolve(); }
    }
    
    // Text to Speech
    function speakText(text) {
        if (!text || !voiceSettings.autoRead) return;
        playAfricanTune().then(() => {
            setTimeout(() => {
                if ('speechSynthesis' in window) {
                    window.speechSynthesis.cancel();
                    const utterance = new SpeechSynthesisUtterance(text);
                    utterance.lang = voiceSettings.language;
                    utterance.rate = voiceSettings.speed;
                    utterance.pitch = voiceSettings.pitch;
                    if (voiceSettings.style === 'african') {
                        const voices = window.speechSynthesis.getVoices();
                        const africanVoices = voices.filter(v => v.lang.includes('en-NG') || v.lang.includes('en-ZA') || v.lang.includes('en-KE') || v.lang.includes('en-GH'));
                        if (africanVoices.length > 0) utterance.voice = africanVoices[0];
                    }
                    utterance.onstart = () => { const st = document.querySelector('.status-text'); if(st) st.textContent = 'Speaking... 🔊'; };
                    utterance.onend = () => { const st = document.querySelector('.status-text'); if(st && !isListening) st.textContent = 'Ready'; };
                    window.speechSynthesis.speak(utterance);
                }
            }, 300);
        });
    }
    
    // Speech Recognition
    function initSpeechRecognition() {
        if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
            if (voiceBtn) { voiceBtn.style.opacity = '0.5'; voiceBtn.title = 'Speech recognition not supported'; }
            return;
        }
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        recognition = new SpeechRecognition();
        recognition.continuous = false;
        recognition.interimResults = true;
        recognition.lang = voiceSettings.language;
        recognition.onstart = () => {
            isListening = true;
            if (voiceBtn) voiceBtn.classList.add('recording');
            const wave = document.querySelector('.voice-wave');
            if (wave) wave.classList.add('active');
            const st = document.querySelector('.status-text');
            if (st) st.textContent = 'Listening... Speak now';
        };
        recognition.onresult = (event) => {
            let finalTranscript = '';
            for (let i = event.resultIndex; i < event.results.length; i++) {
                if (event.results[i].isFinal) finalTranscript += event.results[i][0].transcript;
            }
            if (chatInput && finalTranscript) {
                chatInput.value = finalTranscript;
                recognition.stop();
                setTimeout(() => sendMessage(), 300);
            }
        };
        recognition.onerror = (event) => {
            console.error('Recognition error:', event.error);
            stopListening();
            const st = document.querySelector('.status-text');
            if (st) st.textContent = 'Error: ' + event.error;
            setTimeout(() => { if(st && !isListening) st.textContent = 'Ready'; }, 2000);
        };
        recognition.onend = () => { stopListening(); const st = document.querySelector('.status-text'); if(st && !isListening) st.textContent = 'Ready'; };
    }
    
    function startListening() {
        if (!recognition) { alert('Speech recognition not supported in this browser. Please use Chrome, Edge, or Safari.'); return; }
        if (isListening) { stopListening(); return; }
        recognition.lang = voiceSettings.language;
        recognition.start();
    }
    
    function stopListening() {
        if (recognition && isListening) recognition.stop();
        isListening = false;
        if (voiceBtn) voiceBtn.classList.remove('recording');
        const wave = document.querySelector('.voice-wave');
        if (wave) wave.classList.remove('active');
    }
    
    function testVoice() {
        const phrases = { 'en-US': 'Hello! This is your Compassionate Capitalism AI assistant.', 'en-GB': 'Hello! This is your Compassionate Capitalism AI assistant.', 'en-NG': 'Hello! This is your Compassionate Capitalism AI assistant.', 'en-ZA': 'Hello! This is your Compassionate Capitalism AI assistant.', 'en-KE': 'Hello! This is your Compassionate Capitalism AI assistant.', 'en-GH': 'Hello! This is your Compassionate Capitalism AI assistant.' };
        speakText(phrases[voiceSettings.language] || phrases['en-US']);
    }
    
    function applyVoiceSettings() {
        voiceSettings.language = document.getElementById('voiceLanguage').value;
        voiceSettings.style = document.getElementById('voiceStyle').value;
        voiceSettings.speed = parseFloat(document.getElementById('voiceSpeed').value);
        voiceSettings.pitch = parseFloat(document.getElementById('voicePitch').value);
        voiceSettings.autoRead = document.getElementById('autoReadResponse').checked;
        voiceSettings.playAfricanTune = document.getElementById('playAfricanTune').checked;
        saveVoiceSettings();
        if (recognition) recognition.lang = voiceSettings.language;
    }
    
    // Chat Functions
    function toggleChat() {
        if (chatModal) {
            chatModal.classList.toggle('active');
            if (chatModal.classList.contains('active')) {
                setTimeout(() => chatInput.focus(), 100);
                if (notificationBadge) notificationBadge.style.display = 'none';
            }
        }
    }
    
    function closeChatModal() { if (chatModal) chatModal.classList.remove('active'); }
    
    if (chatButton) chatButton.addEventListener('click', (e) => { e.preventDefault(); toggleChat(); });
    if (closeChat) closeChat.addEventListener('click', (e) => { e.preventDefault(); closeChatModal(); });
    if (voiceBtn) voiceBtn.addEventListener('click', startListening);
    if (voiceToggleBtn) voiceToggleBtn.addEventListener('click', () => { if (voiceSettingsModal) voiceSettingsModal.style.display = 'flex'; });
    if (closeSettingsBtn) closeSettingsBtn.addEventListener('click', () => { if (voiceSettingsModal) voiceSettingsModal.style.display = 'none'; });
    if (testVoiceBtn) testVoiceBtn.addEventListener('click', testVoice);
    
    const voiceLang = document.getElementById('voiceLanguage');
    const voiceStyle = document.getElementById('voiceStyle');
    const voiceSpeed = document.getElementById('voiceSpeed');
    const voicePitch = document.getElementById('voicePitch');
    const autoRead = document.getElementById('autoReadResponse');
    const playTune = document.getElementById('playAfricanTune');
    if (voiceSpeed) voiceSpeed.addEventListener('input', updateSpeedDisplay);
    if (voicePitch) voicePitch.addEventListener('input', updatePitchDisplay);
    if (voiceLang) voiceLang.addEventListener('change', applyVoiceSettings);
    if (voiceStyle) voiceStyle.addEventListener('change', applyVoiceSettings);
    if (voiceSpeed) voiceSpeed.addEventListener('change', applyVoiceSettings);
    if (voicePitch) voicePitch.addEventListener('change', applyVoiceSettings);
    if (autoRead) autoRead.addEventListener('change', applyVoiceSettings);
    if (playTune) playTune.addEventListener('change', applyVoiceSettings);
    
    window.addEventListener('click', (e) => {
        if (voiceSettingsModal && e.target === voiceSettingsModal) voiceSettingsModal.style.display = 'none';
        if (chatModal && chatModal.classList.contains('active')) {
            if (!chatModal.contains(e.target) && !chatButton.contains(e.target)) closeChatModal();
        }
    });
    
    if (chatInput) {
        chatInput.addEventListener('input', function() { this.style.height = 'auto'; this.style.height = Math.min(this.scrollHeight, 80) + 'px'; });
        chatInput.addEventListener('keypress', (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } });
    }
    
    async function sendMessage() {
        if (!chatInput) return;
        const message = chatInput.value.trim();
        if (!message || isTyping) return;
        addMessage(message, 'sent');
        chatInput.value = '';
        chatInput.style.height = 'auto';
        showTypingIndicator();
        isTyping = true;
        try {
            const response = await fetch('/api/chat/send', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: message, sessionId: sessionId }) });
            let reply;
            if (response.ok) { const data = await response.json(); reply = data.success ? data.reply : getFallbackResponse(message); }
            else { reply = getFallbackResponse(message); }
            hideTypingIndicator();
            addMessage(reply, 'received');
        } catch (error) {
            hideTypingIndicator();
            addMessage(getFallbackResponse(message), 'received');
        } finally { isTyping = false; }
    }
    
    function getFallbackResponse(message) {
        const lower = message.toLowerCase();
        if (/hello|hi|hey/.test(lower)) return 'Hello! 👋 How can I assist you with Compassionate Capitalism today?';
        if (/what is compassionate capitalism|what is cc/.test(lower)) return 'Compassionate Capitalism combines free market principles with social responsibility, focusing on ethical business practices and sustainability.';
        if (/services|what services/.test(lower)) return 'We offer investment advisory, business consulting, educational programs, and community development initiatives.';
        if (/contact|support/.test(lower)) return 'Contact us at support@redirectmall.com or call +1 (345) 909-6565.';
        if (/thank|thanks/.test(lower)) return "You're welcome! Is there anything else I can help with?";
        return "Thank you for your question. Please visit our website or contact support for more information.";
    }
    
    function addMessage(text, type) {
        if (!chatMessages) return;
        const div = document.createElement('div');
        div.className = `message ${type}`;
        const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        div.innerHTML = `<div class="message-content"><p>${escapeHtml(text)}</p><span class="message-time">${time}</span></div>`;
        chatMessages.appendChild(div);
        scrollToBottom();
        if (type === 'received' && voiceSettings.autoRead) speakText(text);
    }
    
    function showTypingIndicator() {
        if (!chatMessages) return;
        const div = document.createElement('div');
        div.className = 'message received';
        div.id = 'typingIndicator';
        div.innerHTML = '<div class="message-content"><div class="typing-indicator"><span></span><span></span><span></span></div></div>';
        chatMessages.appendChild(div);
        scrollToBottom();
    }
    
    function hideTypingIndicator() { const ind = document.getElementById('typingIndicator'); if (ind) ind.remove(); }
    function scrollToBottom() { if (chatMessages) chatMessages.scrollTop = chatMessages.scrollHeight; }
    function escapeHtml(text) { const div = document.createElement('div'); div.textContent = text; return div.innerHTML; }
    
    if (sendButton) sendButton.addEventListener('click', sendMessage);
    document.querySelectorAll('.option-btn').forEach(btn => {
        btn.addEventListener('click', () => { const q = btn.getAttribute('data-question'); if (q && chatInput) { chatInput.value = q; sendMessage(); } });
    });
    
    setTimeout(() => { if (!localStorage.getItem('chatWelcomeShown')) { if (notificationBadge) notificationBadge.style.display = 'flex'; localStorage.setItem('chatWelcomeShown', 'true'); } }, 2000);
    
    loadVoiceSettings();
    initSpeechRecognition();
})();

// ============================================
// COOKIE CONSENT MANAGEMENT
// ============================================
(function() {
    const COOKIE_CONSENT_KEY = 'cookiePreferences';
    function getPrefs() { const p = localStorage.getItem(COOKIE_CONSENT_KEY); return p ? JSON.parse(p) : null; }
    function setPrefs(prefs) { localStorage.setItem(COOKIE_CONSENT_KEY, JSON.stringify(prefs)); }
    function showBanner() { const b = document.getElementById('cookieBanner'); if (b) b.style.display = 'block'; }
    function hideBanner() { const b = document.getElementById('cookieBanner'); if (b) b.style.display = 'none'; }
    function showModal() { const m = document.getElementById('cookieConsentModal'); if (m) { const p = getPrefs(); if(p){ document.getElementById('functionalCookies').checked = p.functional; document.getElementById('analyticsCookies').checked = p.analytics; document.getElementById('marketingCookies').checked = p.marketing; } m.style.display = 'flex'; } }
    function hideModal() { const m = document.getElementById('cookieConsentModal'); if (m) m.style.display = 'none'; }
    function acceptAll() { setPrefs({ essential: true, functional: true, analytics: true, marketing: true, accepted: true }); hideBanner(); hideModal(); }
    function declineNonEssential() { setPrefs({ essential: true, functional: false, analytics: false, marketing: false, accepted: true }); hideBanner(); hideModal(); }
    function savePrefs() { setPrefs({ essential: true, functional: document.getElementById('functionalCookies').checked, analytics: document.getElementById('analyticsCookies').checked, marketing: document.getElementById('marketingCookies').checked, accepted: true }); hideBanner(); hideModal(); }
    
    if (!getPrefs()) showBanner();
    document.getElementById('acceptAllCookies')?.addEventListener('click', acceptAll);
    document.getElementById('customizeCookies')?.addEventListener('click', showModal);
    document.getElementById('cookieSettingsLink')?.addEventListener('click', (e) => { e.preventDefault(); showModal(); });
    document.getElementById('cookiePolicyLink')?.addEventListener('click', (e) => { e.preventDefault(); showModal(); });
    document.getElementById('closeCookieModal')?.addEventListener('click', hideModal);
    document.getElementById('declineCookies')?.addEventListener('click', declineNonEssential);
    document.getElementById('acceptCookies')?.addEventListener('click', acceptAll);
    document.getElementById('saveCookiePrefs')?.addEventListener('click', savePrefs);
    window.addEventListener('click', (e) => { const m = document.getElementById('cookieConsentModal'); if (m && m.style.display === 'flex' && e.target === m) hideModal(); });
})();


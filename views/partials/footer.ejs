    background: #2d2d44;
    color: white;
}
.cookie-btn-primary:hover, .cookie-btn-save:hover { transform: scale(1.02); }
.cookie-btn-secondary:hover { background: rgba(102,126,234,0.1); }

@keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }

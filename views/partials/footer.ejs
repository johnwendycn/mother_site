}
.cookie-btn {
    padding: 10px 24px;
    border-radius: 30px;
    border: none;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.3s ease;
}
.cookie-btn-primary {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
}
.cookie-btn-secondary {
    background: transparent;
    border: 1px solid #667eea;
    color: #667eea;
}

}
.cookie-close:hover { color: #667eea; }
.cookie-modal-body { padding: 25px; }
.cookie-modal-body > p { color: #b0b0b0; margin-bottom: 20px; line-height: 1.6; }
.cookie-preferences { display: flex; flex-direction: column; gap: 20px; }
.cookie-preference {
    display: flex;
    gap: 15px;
    align-items: flex-start;
    padding: 12px;
    background: rgba(255,255,255,0.03);
    border-radius: 12px;
}
.cookie-preference-info h4 { margin: 0 0 5px 0; color: #fff; font-size: 15px; }
.cookie-preference-info p { margin: 0; color: #888; font-size: 12px; line-height: 1.5; }
.cookie-switch {
    position: relative;
    display: inline-block;
    width: 50px;
    height: 24px;
    flex-shrink: 0;
}

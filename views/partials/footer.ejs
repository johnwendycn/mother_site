    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
}

/* Responsive */
@media (max-width: 991px) {
    .footer-main { padding: 40px 0 20px; }
    .footer-widget { margin-bottom: 40px; }
}

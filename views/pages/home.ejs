        #rs-video-advanced .video-subtitle {
            font-size: 1rem;
        }
        
        #rs-video-advanced .popup-vimeo {
            padding: 10px 24px;
        }
        
        .vr-modal-header {
            padding: 1rem;
        }
        
        .vr-modal-header h2 {
            font-size: 0.9rem;
        }
        
        .vr-modal-body {
            padding: 1rem;

<script>
    // Advanced Lightning and Thunder Effects
    (function() {
        // Create lightning container
        const historySection = document.querySelector('.rs-history');
        if (!historySection) return;
        
        const lightningContainer = document.createElement('div');
        lightningContainer.className = 'lightning-container';
        historySection.insertBefore(lightningContainer, historySection.firstChild);
        
        // Function to create random lightning bolt
        function createLightningBolt() {
            const bolt = document.createElement('div');
            bolt.className = 'lightning-bolt';
            
            // Random position
            const left = Math.random() * 100;
            const randomRotation = (Math.random() - 0.5) * 30;
            
            bolt.style.left = left + '%';
            bolt.style.top = '0px';
            bolt.style.transform = `rotate(${randomRotation}deg)`;
            bolt.style.position = 'absolute';
            bolt.style.zIndex = '20';
            
            // Random height
            const height = 150 + Math.random() * 200;
            bolt.style.height = height + 'px';
            
            lightningContainer.appendChild(bolt);
            
            // Create flash effect
            const flash = document.createElement('div');
            flash.className = 'lightning-flash';
            document.body.appendChild(flash);
            setTimeout(() => flash.remove(), 100);
            
            // Remove bolt after animation
            setTimeout(() => {
                bolt.remove();
            }, 800);
        }
        
        // Create random lightning flashes
        function randomLightning() {
            // Random interval between 5 and 15 seconds
            const interval = 5000 + Math.random() * 10000;
            
            setTimeout(() => {
                // Create multiple bolts sometimes
                const boltCount = Math.random() > 0.8 ? 2 + Math.random() * 3 : 1;
                
                for (let i = 0; i < boltCount; i++) {
                    setTimeout(() => createLightningBolt(), i * 80);
                }
                
                randomLightning();
            }, interval);
        }
        
        // Start lightning after a short delay
        setTimeout(randomLightning, 3000);
        
        // Create floating clouds dynamically
        function createFloatingCloud() {
            const cloud = document.createElement('div');
            cloud.className = 'floating-cloud';
            cloud.innerHTML = '<i class="fa fa-cloud" style="font-size: 60px; color: #fff;"></i>';
            cloud.style.position = 'absolute';
            cloud.style.bottom = Math.random() * 100 + '%';
            cloud.style.left = '-80px';
            cloud.style.animation = `floatCloud ${15 + Math.random() * 15}s linear infinite`;
            cloud.style.opacity = 0.1;
            
            historySection.appendChild(cloud);
            
            setTimeout(() => cloud.remove(), 25000);
        }
        
        // Add floating cloud style
        const style = document.createElement('style');
        style.textContent = `
            @keyframes floatCloud {
                0% { left: -80px; }
                100% { left: 100%; }
            }
        `;
        document.head.appendChild(style);
        
        // Create occasional floating clouds
        setInterval(createFloatingCloud, 10000);
        
    })();
</script>


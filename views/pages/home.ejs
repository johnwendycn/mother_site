    /* ANIMATED BLACK MODAL POPUP */
    .vr-modal {
        display: none;
        position: fixed;
        z-index: 10000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
    }

    .vr-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #000000;
        opacity: 0;
        transition: opacity 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    }

    .vr-modal-container {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transform: scale(0.9) translateY(30px);
        transition: all 0.5s cubic-bezier(0.2, 0.9, 0.4, 1.2);
    }

    .vr-modal.show {
        display: block;
    }

    .vr-modal.show .vr-modal-overlay {
        opacity: 0.96;
    }

    .vr-modal.show .vr-modal-container {
        opacity: 1;
        transform: scale(1) translateY(0);
    }

    .vr-modal-content {
        position: relative;
        background: linear-gradient(135deg, #0a0a0a 0%, #0d0d1a 50%, #0a0a15 100%);
        margin: 0 auto;
        padding: 0;
        width: 85%;
        max-width: 1100px;
        border-radius: 32px;
        box-shadow: 0 0 80px rgba(0, 255, 255, 0.4), 0 0 40px rgba(255, 0, 255, 0.3), inset 0 1px 0 rgba(0, 255, 255, 0.2);
        border: 2px solid rgba(0, 255, 255, 0.7);
        overflow: hidden;
    }

    .vr-modal-header {
        padding: 1rem 2rem;
        background: rgba(0, 0, 0, 0.6);
        border-bottom: 1px solid rgba(0, 255, 255, 0.4);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .vr-modal-header h2 {
        margin: 0;
        font-size: 1.3rem;
        font-weight: 700;
        background: linear-gradient(120deg, #00ffff, #ff66ff, #00ffff);
        background-size: 200% auto;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        letter-spacing: 3px;
        font-family: 'Inter', monospace;
        animation: headerGlow 3s ease infinite;
    }

    @keyframes headerGlow {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    .vr-modal-close-wrapper {
        cursor: pointer;
    }

    .vr-modal-close {
        color: #00ffff;
        font-size: 42px;
        font-weight: bold;

        display: flex;
        align-items: center;
        gap: 12px;
    }

    .modal-title-wrapper i {
        font-size: 1.5rem;
        color: #ff3c00;
    }

    .vr-modal-header h2 {
        margin: 0;
        font-size: 1.2rem;
        font-weight: 700;
        background: linear-gradient(135deg, #00ffff, #ff66ff);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        letter-spacing: 2px;
    }

    .vr-modal-close {
        color: #fff;
        font-size: 32px;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s ease;
        opacity: 0.7;
    }

    .vr-modal-close:hover {
        opacity: 1;
        transform: rotate(90deg);
        color: #ff3c00;
    }

    .vr-modal-body {
        padding: 2rem;
    }

    .video-wrapper {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
        border-radius: 16px;
        background: #000;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .video-wrapper iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }

    .video-caption {
        margin-top: 1rem;
        text-align: center;
    }

    .video-caption p {
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.9rem;
        margin: 0;
    }

    /* Animations */
    @keyframes rs-rotateGlow {
        0% { transform: rotate(0deg); opacity: 0.3; }
        50% { transform: rotate(5deg); opacity: 0.6; }
        100% { transform: rotate(360deg); opacity: 0.3; }
    }

    @keyframes rs-vrGradientFlow {
        0% { background-position: 0% 30%; opacity: 0.4; }
        100% { background-position: 100% 70%; opacity: 0.8; }
    }

    @keyframes rs-boltStrike {
        0% { opacity: 0; transform: scaleX(0.3); }
        10% { opacity: 1; transform: scaleX(1); filter: blur(2px); }
        30% { opacity: 0.6; transform: scaleX(1.1); }
        70% { opacity: 0.2; transform: scaleX(0.9); }
        100% { opacity: 0; transform: scaleX(0.2); filter: blur(8px); }
    }

    @keyframes rs-scanMove {
        0% { background-position: 0 0; }
        100% { background-position: 0 100%; }
    }

    @keyframes rs-textShift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    @keyframes rs-pulse {
        0%, 100% { opacity: 0.7; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.05); }
    }

    /* Responsive */
    @media (max-width: 768px) {
        #rs-video-advanced .video-title {
            font-size: 1.8rem;
            letter-spacing: 2px;

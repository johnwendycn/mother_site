<script>
    // Symbolic Canvas Animation - Representing Struggle and Resilience
    (function() {
        const canvas = document.getElementById('symbolicCanvas');
        if (!canvas) return;
        
        function resizeCanvas() {
            const container = canvas.parentElement;
            const size = Math.min(container.clientWidth, 500);
            canvas.width = size;
            canvas.height = size;
            drawSymbolicScene();
        }
        
        const ctx = canvas.getContext('2d');
        
        function drawSymbolicScene() {
            if (!ctx) return;
            
            const w = canvas.width;
            const h = canvas.height;
            
            // Clear canvas
            ctx.clearRect(0, 0, w, h);
            
            // Draw burning/smoldering city skyline silhouette
            ctx.fillStyle = '#1a1a2e';
            ctx.fillRect(0, 0, w, h);
            
            // Draw city skyline (destroyed buildings)
            ctx.fillStyle = '#2d2d44';
            const buildingWidth = w / 12;
            for (let i = 0; i < 12; i++) {
                const height = 80 + Math.sin(i) * 40 + Math.random() * 30;
                const x = i * buildingWidth;
                const y = h - height;
                ctx.fillRect(x, y, buildingWidth - 2, height);
                
                // Broken windows
                ctx.fillStyle = '#DC0028';
                for (let ww = 0; ww < 3; ww++) {
                    ctx.fillRect(x + 10, y + 20 + ww * 25, 15, 10);
                }
                ctx.fillStyle = '#2d2d44';
            }
            
            // Draw smoke rising from buildings
            ctx.fillStyle = 'rgba(150, 150, 150, 0.3)';
            for (let i = 0; i < 20; i++) {
                ctx.beginPath();
                ctx.arc(50 + i * 40, h - 150 - Math.sin(Date.now() * 0.001 + i) * 20, 20, 0, Math.PI * 2);
                ctx.fill();
            }
            
            // Draw symbolic broken chain (representing oppression)
            ctx.beginPath();
            ctx.strokeStyle = '#DC0028';
            ctx.lineWidth = 3;
            for (let i = 0; i < 8; i++) {
                const x = 50 + i * 50;
                const y = h - 180;
                ctx.beginPath();
                ctx.arc(x, y, 12, 0, Math.PI * 2);
                ctx.stroke();
                if (i < 7) {
                    ctx.beginPath();
                    ctx.moveTo(x + 12, y);
                    ctx.lineTo(x + 38, y);
                    ctx.stroke();
                }
            }
            
            // Draw broken chain links
            ctx.fillStyle = '#DC0028';
            ctx.beginPath();
            ctx.arc(250, h - 180, 10, 0, Math.PI * 2);
            ctx.fill();
            
            // Draw rising phoenix/sun (symbol of rebirth)
            const time = Date.now() * 0.002;
            const sunY = h - 250 + Math.sin(time) * 10;
            ctx.beginPath();
            ctx.arc(w - 80, sunY, 30, 0, Math.PI * 2);
            ctx.fillStyle = '#ffd700';
            ctx.fill();
            
            // Sun rays
            for (let i = 0; i < 12; i++) {
                const angle = (i * 30 + time * 50) * Math.PI / 180;
                const x1 = w - 80 + Math.cos(angle) * 40;
                const y1 = sunY + Math.sin(angle) * 40;
                const x2 = w - 80 + Math.cos(angle) * 60;
                const y2 = sunY + Math.sin(angle) * 60;
                ctx.beginPath();
                ctx.moveTo(x1, y1);
                ctx.lineTo(x2, y2);
                ctx.strokeStyle = '#ffd700';
                ctx.lineWidth = 2;
                ctx.stroke();
            }
            
            // Draw silhouettes of people (resilience)
            ctx.fillStyle = '#1a1a2e';
            for (let i = 0; i < 5; i++) {
                const x = 80 + i * 80;
                const y = h - 60;
                ctx.beginPath();
                ctx.arc(x, y - 20, 12, 0, Math.PI * 2);
                ctx.fill();
                ctx.fillRect(x - 10, y - 20, 20, 40);
            }
            
            // Draw hands reaching up (hope)
            for (let i = 0; i < 8; i++) {
                const x = 30 + i * 60;
                const y = h - 70;
                ctx.beginPath();
                ctx.moveTo(x, y);
                ctx.lineTo(x - 8, y - 25);
                ctx.lineTo(x, y - 15);
                ctx.lineTo(x + 8, y - 25);
                ctx.fill();
                ctx.fillStyle = '#2d2d44';
            }
            
            // Draw tears/rain (symbolizing sorrow)
            ctx.fillStyle = 'rgba(100, 150, 200, 0.5)';
            for (let i = 0; i < 30; i++) {
                const dropX = 20 + i * 25;
                const dropY = h - 300 + Math.sin(Date.now() * 0.003 + i) * 20;
                ctx.fillRect(dropX, dropY, 2, 8);
            }
            
            // Animate
            requestAnimationFrame(() => {
                drawSymbolicScene();
            });
        }
        
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);
    })();
    
    // Smoke Animation for Background
    (function() {
        const canvas = document.getElementById('smokeCanvas');
        if (!canvas) return;
        
        function resizeCanvas() {
            const section = document.querySelector('.blackwall-street-section');
            if (section) {
                canvas.width = section.offsetWidth;
                canvas.height = section.offsetHeight;
            }
        }
        
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);
        
        const ctx = canvas.getContext('2d');
        
        let particles = [];
        const particleCount = 50;
        
        class SmokeParticle {
            constructor(width, height) {
                this.x = Math.random() * width;
                this.y = height + Math.random() * 100;
                this.size = 40 + Math.random() * 80;
                this.speedY = -0.5 - Math.random() * 1;
                this.speedX = (Math.random() - 0.5) * 0.3;
                this.opacity = 0.05 + Math.random() * 0.1;
            }
            
            update(width, height) {
                this.x += this.speedX;
                this.y += this.speedY;
                
                if (this.y < -100 || this.x < -100 || this.x > width + 100) {
                    this.x = Math.random() * width;
                    this.y = height + Math.random() * 50;
                    this.opacity = 0.05 + Math.random() * 0.1;
                }
            }
            
            draw(ctx) {
                ctx.save();
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(150, 150, 150, ${this.opacity})`;
                ctx.fill();
                ctx.restore();
            }
        }
        
        function initParticles() {
            particles = [];
            for (let i = 0; i < particleCount; i++) {
                particles.push(new SmokeParticle(canvas.width, canvas.height));
            }
        }
        
        function animateSmoke() {
            if (!ctx || !canvas) return;
            
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            for (let particle of particles) {
                particle.update(canvas.width, canvas.height);
                particle.draw(ctx);
            }
            
            requestAnimationFrame(animateSmoke);
        }
        
        setTimeout(() => {
            initParticles();
            animateSmoke();
        }, 100);
        
        let resizeTimeout;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(() => {
                resizeCanvas();
                initParticles();
            }, 250);
        });
    })();
</script>

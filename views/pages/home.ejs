<script>
    (function() {
        const searchInput = document.getElementById('liveSearchInput');
        const clearBtn = document.getElementById('clearSearchBtn');
        const searchStats = document.getElementById('searchStats');
        const matchCountSpan = document.getElementById('matchCount');
        const searchNavigation = document.getElementById('searchNavigation');
        const prevMatchBtn = document.getElementById('prevMatchBtn');
        const nextMatchBtn = document.getElementById('nextMatchBtn');
        
        let currentMatches = [];
        let currentMatchIndex = -1;
        let debounceTimer;
        let isHighlighting = false;
        
        // Helper function to escape regex special characters
        function escapeRegex(string) {
            return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        }
        
        // Function to clear all highlights
        function clearHighlights() {
            const highlighted = document.querySelectorAll('.search-highlight');
            highlighted.forEach(el => {
                const parent = el.parentNode;
                if (parent) {
                    parent.replaceChild(document.createTextNode(el.textContent), el);
                    parent.normalize();
                }
            });
            currentMatches = [];
            currentMatchIndex = -1;
            if (searchStats) searchStats.style.display = 'none';
            if (searchNavigation) searchNavigation.style.display = 'none';
        }
        
        // Function to get all text nodes excluding script/style tags and the search input
        function getTextNodes() {
            const walker = document.createTreeWalker(
                document.body,
                NodeFilter.SHOW_TEXT,
                {
                    acceptNode: function(node) {
                        // Exclude script, style, and the search input area
                        if (node.parentElement.tagName === 'SCRIPT' || 
                            node.parentElement.tagName === 'STYLE' ||
                            node.parentElement.tagName === 'NOSCRIPT' ||
                            node.parentElement.classList?.contains('search-highlight') ||
                            node.parentElement.id === 'liveSearchInput' ||
                            node.parentElement.closest('.rs-search-courses')) {
                            return NodeFilter.FILTER_REJECT;
                        }
                        // Exclude empty text nodes
                        if (node.nodeValue.trim() === '') {
                            return NodeFilter.FILTER_REJECT;
                        }
                        return NodeFilter.FILTER_ACCEPT;
                    }
                }
            );
            
            const textNodes = [];
            while (walker.nextNode()) {
                textNodes.push(walker.currentNode);
            }
            return textNodes;
        }
        
        // Function to find all matches and highlight them
        function highlightText(searchTerm) {
            if (isHighlighting) return;
            isHighlighting = true;
            
            try {
                if (!searchTerm || searchTerm.trim() === '') {
                    clearHighlights();
                    if (clearBtn) clearBtn.style.display = 'none';
                    isHighlighting = false;
                    return;
                }
                
                clearHighlights();
                
                const escapedTerm = escapeRegex(searchTerm);
                const regex = new RegExp(`(${escapedTerm})`, 'gi');
                const textNodes = getTextNodes();
                
                let matchCount = 0;
                const newMatches = [];
                
                textNodes.forEach(node => {
                    const text = node.nodeValue;
                    if (regex.test(text)) {
                        const span = document.createElement('span');
                        span.className = 'search-highlight';
                        const replacedHtml = text.replace(regex, (match) => {
                            matchCount++;
                            return `<mark data-match-index="${matchCount - 1}">${match}</mark>`;
                        });
                        span.innerHTML = replacedHtml;
                        node.parentNode.replaceChild(span, node);
                    }
                });
                
                // Collect all mark elements
                const marks = document.querySelectorAll('.search-highlight mark');
                marks.forEach((mark, idx) => {
                    mark.setAttribute('data-match-index', idx);
                    newMatches.push(mark);
                });
                
                currentMatches = newMatches;
                
                // Update stats display
                if (matchCount > 0) {
                    if (searchStats) {
                        matchCountSpan.textContent = matchCount;
                        searchStats.style.display = 'block';
                    }
                    if (searchNavigation) searchNavigation.style.display = 'flex';
                    currentMatchIndex = 0;
                    highlightCurrentMatch();
                } else {
                    if (searchStats) {
                        matchCountSpan.textContent = '0';
                        searchStats.style.display = 'block';
                    }
                    if (searchNavigation) searchNavigation.style.display = 'none';
                }
                
                if (clearBtn) clearBtn.style.display = searchTerm ? 'block' : 'none';
                
            } catch (error) {
                console.error('Search error:', error);
            } finally {
                isHighlighting = false;
            }
        }
        
        // Function to highlight the current match and scroll to it
        function highlightCurrentMatch() {
            // Remove current highlight from all marks
            document.querySelectorAll('.search-highlight mark').forEach(mark => {
                mark.classList.remove('current');
                mark.style.background = '#ffeb3b';
                mark.style.color = '#DC0028';
            });
            
            if (currentMatches.length > 0 && currentMatchIndex >= 0 && currentMatchIndex < currentMatches.length) {
                const currentMatch = currentMatches[currentMatchIndex];
                currentMatch.classList.add('current');
                currentMatch.style.background = '#DC0028';
                currentMatch.style.color = 'white';
                
                // Scroll to the current match
                currentMatch.scrollIntoView({ behavior: 'smooth', block: 'center' });
                
                // Update match count display
                if (matchCountSpan) {
                    matchCountSpan.textContent = `${currentMatchIndex + 1} of ${currentMatches.length}`;
                }
            } else if (currentMatches.length > 0) {
                if (matchCountSpan) {
                    matchCountSpan.textContent = `${currentMatches.length} matches found`;
                }
            }
        }
        
        // Navigate to next match
        function nextMatch() {
            if (currentMatches.length === 0) return;
            
            if (currentMatchIndex < currentMatches.length - 1) {
                currentMatchIndex++;
            } else {
                currentMatchIndex = 0; // Loop back to first
            }
            highlightCurrentMatch();
        }
        
        // Navigate to previous match
        function prevMatch() {
            if (currentMatches.length === 0) return;
            
            if (currentMatchIndex > 0) {
                currentMatchIndex--;
            } else {
                currentMatchIndex = currentMatches.length - 1; // Loop to last
            }
            highlightCurrentMatch();
        }
        
        // Clear search
        function clearSearch() {
            if (searchInput) {
                searchInput.value = '';
                clearHighlights();
                if (clearBtn) clearBtn.style.display = 'none';
                if (searchStats) searchStats.style.display = 'none';
                if (searchNavigation) searchNavigation.style.display = 'none';
                searchInput.focus();
            }
        }
        
        // Event Listeners
        if (searchInput) {
            searchInput.addEventListener('input', function(e) {
                clearTimeout(debounceTimer);
                const searchTerm = e.target.value;
                
                debounceTimer = setTimeout(() => {
                    highlightText(searchTerm);
                }, 300);
            });
            
            // Keyboard shortcuts
            searchInput.addEventListener('keydown', function(e) {
                // Ctrl+F to focus search (browser default will still work)
                if (e.ctrlKey && e.key === 'f') {
                    e.preventDefault();
                    this.focus();
                    this.select();
                }
                // Enter key to go to first match
                if (e.key === 'Enter' && currentMatches.length > 0) {
                    e.preventDefault();
                    if (currentMatchIndex === -1) {
                        currentMatchIndex = 0;
                        highlightCurrentMatch();
                    } else {
                        nextMatch();
                    }
                }
                // Escape to clear search
                if (e.key === 'Escape') {
                    clearSearch();
                }
            });
        }
        
        if (clearBtn) {
            clearBtn.addEventListener('click', clearSearch);
        }
        
        if (nextMatchBtn) {
            nextMatchBtn.addEventListener('click', nextMatch);
        }
        
        if (prevMatchBtn) {
            prevMatchBtn.addEventListener('click', prevMatch);
        }
        
        // Keyboard navigation for next/previous (when search is focused)
        document.addEventListener('keydown', function(e) {
            // Only handle if search input is focused
            if (document.activeElement === searchInput && currentMatches.length > 0) {
                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    nextMatch();
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    prevMatch();
                }
            }
        });
        
        // Optional: Add F3 key to find next match
        document.addEventListener('keydown', function(e) {
            if (e.key === 'F3') {
                e.preventDefault();
                if (currentMatches.length > 0) {
                    nextMatch();
                } else if (searchInput && searchInput.value.trim()) {
                    highlightText(searchInput.value.trim());
                    setTimeout(() => nextMatch(), 100);
                } else if (searchInput) {
                    searchInput.focus();
                    searchInput.select();
                }
            }
            
            // Shift+F3 for previous match
            if (e.shiftKey && e.key === 'F3') {
                e.preventDefault();
                if (currentMatches.length > 0) {
                    prevMatch();
                }
            }
        });
    })();
</script>



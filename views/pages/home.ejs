<!-- Lightning Canvas Animation Script -->
<script>
(function() {
    const canvas = document.getElementById('lightningCanvas');
    if (!canvas) return;
    let ctx = canvas.getContext('2d');
    let width, height, flashIntensity = 0, lightnings = [];
    
    function resizeCanvas() {
        const section = document.querySelector('.bws-hero-section');
        if (section) { width = section.offsetWidth; height = section.offsetHeight; canvas.width = width; canvas.height = height; }
    }
    
    class LightningBolt {
        constructor(x, y, targetY) {
            this.x = x; this.y = y; this.targetY = targetY; this.segments = [];
            this.thickness = 3; this.opacity = 1; this.age = 0; this.maxAge = 20 + Math.random() * 15;
            this.generateBolt();
        }
        generateBolt() {
            let currentX = this.x, currentY = this.y;
            const segmentCount = 8 + Math.floor(Math.random() * 8);
            for (let i = 0; i <= segmentCount; i++) {
                const t = i / segmentCount;
                const targetX = this.x + (Math.random() - 0.5) * 60 * (1 - t);
                const targetY = this.y + (this.targetY - this.y) * t;
                this.segments.push({ fromX: currentX, fromY: currentY, toX: targetX, toY: targetY });
                currentX = targetX; currentY = targetY;
            }
        }
        draw(ctx) {
            ctx.save();
            ctx.globalAlpha = this.opacity * (1 - this.age / this.maxAge);
            ctx.lineWidth = this.thickness * (1 - this.age / this.maxAge);
            ctx.strokeStyle = `rgba(255,200,50,${0.9 * (1 - this.age / this.maxAge)})`;
            ctx.shadowBlur = 12; ctx.shadowColor = '#ffaa00';
            for (const seg of this.segments) {
                ctx.beginPath(); ctx.moveTo(seg.fromX, seg.fromY); ctx.lineTo(seg.toX, seg.toY); ctx.stroke();
                if (Math.random() > 0.7 && this.age < 5) {
                    ctx.beginPath(); ctx.moveTo(seg.toX, seg.toY); ctx.lineTo(seg.toX + (Math.random() - 0.5) * 25, seg.toY + (Math.random() - 0.5) * 25); ctx.stroke();
                }
            }
            ctx.restore();
        }
        update() { this.age++; return this.age < this.maxAge; }
    }
    
    function createLightning() {
        const x = 50 + Math.random() * (width - 100);
        lightnings.push(new LightningBolt(x, 0, height));
        const branchCount = 2 + Math.floor(Math.random() * 3);
        for (let i = 0; i < branchCount; i++) {
            const branchX = x + (Math.random() - 0.5) * 80;
            const branchBolt = new LightningBolt(branchX, 40 + Math.random() * 120, height - Math.random() * 100);
            branchBolt.thickness = 1.5;
            lightnings.push(branchBolt);
        }
        flashIntensity = 0.25;
        setTimeout(() => { flashIntensity = 0; }, 120);
        scheduleNextLightning();
    }
    
    function scheduleNextLightning() {
        const delay = 4000 + Math.random() * 6000;
        clearTimeout(window.nextLightningTimeout);
        window.nextLightningTimeout = setTimeout(() => { if (width > 0) createLightning(); }, delay);
    }
    
    function drawFlash() {
        if (flashIntensity > 0) {
            ctx.fillStyle = `rgba(255,245,180,${flashIntensity})`;
            ctx.fillRect(0, 0, width, height);
            flashIntensity *= 0.92;
        }
    }
    
    function animate() {
        if (!ctx || !canvas || width === 0) { requestAnimationFrame(animate); return; }
        ctx.clearRect(0, 0, width, height);
        lightnings = lightnings.filter(bolt => bolt.update());
        lightnings.forEach(bolt => bolt.draw(ctx));
        drawFlash();
        requestAnimationFrame(animate);
    }
    
    window.addEventListener('resize', resizeCanvas);
    setTimeout(() => { resizeCanvas(); animate(); scheduleNextLightning(); }, 500);
})();

// Video Modal Script
(function() {
    const modal = document.getElementById('vr-video-modal');
    const playBtn = document.querySelector('#rs-video-advanced .popup-vimeo');
    const closeBtn = document.querySelector('.vr-modal-close');
    const iframe = document.getElementById('vimeo-player');
    const originalSrc = iframe ? iframe.src : '';
    
    function openModal() { if (modal) { modal.classList.add('show'); document.body.style.overflow = 'hidden'; if (iframe) iframe.src = 'https://player.vimeo.com/video/863884866?autoplay=1&title=0&byline=0&portrait=0&badge=0'; } }
    function closeModal() { if (modal) { modal.classList.remove('show'); document.body.style.overflow = ''; if (iframe) iframe.src = originalSrc; } }
    
    if (playBtn) playBtn.addEventListener('click', (e) => { e.preventDefault(); openModal(); });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    window.addEventListener('click', (e) => { if (modal?.classList.contains('show') && (e.target === modal || e.target.classList.contains('vr-modal-overlay'))) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal?.classList.contains('show')) closeModal(); });
})();

// AOS Initialize
AOS.init({ duration: 1000, once: true, offset: 100 });
</script>


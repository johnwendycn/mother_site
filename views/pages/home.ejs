  (function() {
    // 3D Tilt Effect for Platform Cards
    const platformItems = document.querySelectorAll('#ccpf2-container .ccpf2-platform-item');
    
    platformItems.forEach(card => {
      card.addEventListener('mousemove', function(e) {
        const rect = this.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = (y - centerY) / 35;
        const rotateY = (centerX - x) / 35;
        
        this.style.transform = `translateX(12px) translateY(-4px) perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
      });
      
      card.addEventListener('mouseleave', function() {
        this.style.transform = '';
      });
      
      // Lightning bolt reset on hover
      card.addEventListener('mouseenter', function() {
        const bolts = this.querySelectorAll('.ccpf2-bolt');
        bolts.forEach(bolt => {
          const oldAnim = bolt.style.animation;
          bolt.style.animation = 'none';
          setTimeout(() => { bolt.style.animation = oldAnim || 'ccpf2-bolt-strike 3s infinite'; }, 20);
        });
      });
    });
    
    // Feature cards 3D effect
    const featureCards = document.querySelectorAll('#ccpf2-container .ccpf2-feature-card');
    featureCards.forEach(card => {
      card.addEventListener('mouseenter', function() {
        this.style.transform = 'translateY(-10px) scale(1.02)';
      });
      card.addEventListener('mouseleave', function() {
        this.style.transform = '';
      });
    });
    
    // Random ambient lightning flash (global within container)
    function addMiniFlash() {
      const container = document.getElementById('ccpf2-container');
      if (!container) return;
      const flash = document.createElement('div');
      flash.style.position = 'absolute';
      flash.style.top = 0;
      flash.style.left = 0;
      flash.style.width = '100%';
      flash.style.height = '100%';
      flash.style.background = 'radial-gradient(circle, rgba(255,255,245,0.08) 0%, rgba(255,255,255,0) 80%)';
      flash.style.pointerEvents = 'none';
      flash.style.zIndex = '100';
      flash.style.transition = 'opacity 0.15s';
      container.appendChild(flash);
      setTimeout(() => {
        flash.style.opacity = '0';
        setTimeout(() => flash.remove(), 200);
      }, 50);
    }
    setInterval(() => {
      if (Math.random() > 0.85) addMiniFlash();
    }, 7000);
  })();
</script>

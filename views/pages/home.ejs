<script>
    // ============================================
    // VGR PARTICLES GENERATION
    // ============================================
    function generateVGRParticles() {
        const container = document.getElementById('vgrParticles');
        if (!container) return;
        
        for (let i = 0; i < 50; i++) {
            const particle = document.createElement('div');
            particle.className = 'vgr-particle';
            particle.style.left = Math.random() * 100 + '%';
            particle.style.top = Math.random() * 100 + '%';
            particle.style.animationDelay = Math.random() * 10 + 's';
            particle.style.animationDuration = 8 + Math.random() * 8 + 's';
            particle.style.width = (2 + Math.random() * 4) + 'px';
            particle.style.height = particle.style.width;
            container.appendChild(particle);
        }
    }
    
    generateVGRParticles();
    
    // ============================================
    // VIDEO PLAY FUNCTION (Lazy Load)
    // ============================================
    function playVideo(element, videoId) {
        const iframe = element.querySelector('iframe');
        if (iframe && !iframe.src) {
            iframe.src = iframe.dataset.src || `https://player.vimeo.com/video/${videoId}?autoplay=1`;
        }
    }
    
    // Lazy load videos on scroll
    const lazyVideos = document.querySelectorAll('.video-thumbnail iframe');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const iframe = entry.target;
                if (iframe.dataset.src && !iframe.src) {
                    iframe.src = iframe.dataset.src;
                }
                observer.unobserve(iframe);
            }
        });
    });
    
    lazyVideos.forEach(video => {
        if (video.dataset.src) {
            observer.observe(video);
        }
    });
    
    // ============================================
    // SCROLL ANIMATIONS
    // ============================================
    const cards = document.querySelectorAll('.vgr-video-card');
    const observerCards = new IntersectionObserver((entries) => {
        entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
                setTimeout(() => {
                    entry.target.style.opacity = '0';
                    entry.target.style.transform = 'translateY(50px)';
                    entry.target.style.transition = 'all 0.6s ease';
                    
                    setTimeout(() => {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }, 50);
                }, index * 150);
                observerCards.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    
    cards.forEach(card => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(50px)';
        observerCards.observe(card);
    });
    
    // ============================================
    // HOLOGRAPHIC MOUSE FOLLOW
    // ============================================
    document.querySelectorAll('.vgr-video-card').forEach(card => {
        card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            const rotateX = (y - centerY) / 25;
            const rotateY = (centerX - x) / 25;
            
            card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-10px)`;
        });
        
        card.addEventListener('mouseleave', () => {
            card.style.transform = '';
        });
    });
</script>


    .vr-modal-body {
        padding: 2rem;
        background: rgba(0, 0, 0, 0.4);
    }

    .video-wrapper {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
        border-radius: 20px;
        box-shadow: 0 0 50px rgba(0, 255, 255, 0.3), inset 0 0 20px rgba(0,255,255,0.1);
    }

    .video-wrapper iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border-radius: 20px;
        border: none;
    }

    /* ANIMATIONS */
    @keyframes rs-rotateGlow {
        0% { transform: rotate(0deg); opacity: 0.4; }
        50% { transform: rotate(10deg); opacity: 0.7; }
        100% { transform: rotate(360deg); opacity: 0.4; }
    }
    @keyframes rs-lightningFlash {
        0% { opacity: 0.15; background-position: 0% 0%; }
        25% { opacity: 0.75; background-position: 15% 5%; }
        50% { opacity: 0.35; background-position: 30% 10%; }
        75% { opacity: 0.85; background-position: 45% 5%; }
        100% { opacity: 0.2; background-position: 100% 0%; }
    }
    @keyframes rs-boltStrike {
        0% { opacity: 0; transform: scaleX(0.3) translateX(-20px); filter: blur(8px); }
        15% { opacity: 1; transform: scaleX(1) translateX(5px); filter: blur(2px); box-shadow: 0 0 20px cyan, 0 0 30px magenta; }
        30% { opacity: 0.8; transform: scaleX(1.1) translateX(10px); }
        70% { opacity: 0.3; transform: scaleX(0.9) translateX(-5px); }
        100% { opacity: 0; transform: scaleX(0.2) translateX(-40px); filter: blur(12px); }
    }
    @keyframes rs-vrGradientFlow {
        0% { background-position: 0% 30%; opacity: 0.5; }
        50% { background-position: 100% 70%; opacity: 0.85; }
        100% { background-position: 0% 30%; opacity: 0.5; }
    }
    @keyframes rs-floatPulse {
        0% { transform: translateY(0px) scale(1); box-shadow: 0 0 15px rgba(0, 255, 255, 0.6), 0 0 30px rgba(255, 0, 255, 0.3); }
        100% { transform: translateY(-12px) scale(1.02); box-shadow: 0 0 35px rgba(0, 255, 255, 0.9), 0 0 55px rgba(255, 0, 255, 0.6); }
    }
    @keyframes rs-textShift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    @keyframes rs-scanMove {
        0% { background-position: 0 0; }
        100% { background-position: 0 100%; }
    }
    @keyframes rs-fadeOutSpark {
        0% { opacity: 0.9; transform: scale(1); }
        100% { opacity: 0; transform: scale(2.5); }
    }

    @media (max-width: 768px) {
        #rs-video-advanced .popup-vimeo { width: 100px; height: 100px; }
        #rs-video-advanced .popup-vimeo i { font-size: 42px; }

<div class="search-navigation" id="searchNavigation">
    <button class="search-nav-btn prev-btn" id="prevMatchBtn">
        <i class="fa fa-chevron-up"></i>
        <span>Previous</span>
    </button>
    <button class="search-nav-btn next-btn" id="nextMatchBtn">
        <span>Next</span>
        <i class="fa fa-chevron-down"></i>
    </button>

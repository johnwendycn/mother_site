<!-- ========== ISOLATED JAVASCRIPT (only targets cc-* elements) ========== -->
<script>
  (function() {
    // Rainfall generation - only for cc-rain-container elements
    function generateRainForContainer(container, intensity = 80) {
      if (!container) return;
      container.innerHTML = '';
      const width = container.offsetWidth;
      if (width === 0) return;
      
      const dropCount = Math.min(Math.floor(intensity * (width / 1920)), 180);
      
      for (let i = 0; i < dropCount; i++) {
        const drop = document.createElement('div');
        drop.classList.add('cc-rain-drop');
        const leftPos = Math.random() * width;
        const duration = 0.7 + Math.random() * 1.3;
        const delay = Math.random() * 5;
        const opacity = 0.4 + Math.random() * 0.5;
        const heightDrop = 8 + Math.random() * 14;
        drop.style.left = leftPos + 'px';
        drop.style.animationDuration = duration + 's';
        drop.style.animationDelay = delay + 's';
        drop.style.opacity = opacity;
        drop.style.height = heightDrop + 'px';
        drop.style.width = (Math.random() * 1.8 + 1.2) + 'px';
        container.appendChild(drop);
      }
    }

    function initAllRain() {
      const rainContainers = document.querySelectorAll('#cc-sections-wrapper .cc-rain-container');
      rainContainers.forEach(container => {
        let intensity = 85;
        if (container.id === 'cc-rain-problem') intensity = 95;
        if (container.id === 'cc-rain-about') intensity = 100;
        generateRainForContainer(container, intensity);
      });
    }
    
    initAllRain();
    let resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(initAllRain, 250);
    });

    // Lightning flash effect (isolated)
    function createSubtleFlash() {
      const flashDiv = document.createElement('div');
      flashDiv.style.position = 'fixed';
      flashDiv.style.top = 0;
      flashDiv.style.left = 0;
      flashDiv.style.width = '100%';
      flashDiv.style.height = '100%';
      flashDiv.style.background = 'radial-gradient(circle, rgba(255,255,245,0.12) 0%, rgba(255,255,255,0) 80%)';
      flashDiv.style.pointerEvents = 'none';
      flashDiv.style.zIndex = '9999';
      flashDiv.style.transition = 'opacity 0.12s ease-out';
      document.body.appendChild(flashDiv);
      setTimeout(() => {
        flashDiv.style.opacity = '0';
        setTimeout(() => flashDiv.remove(), 180);
      }, 40);
    }

    setInterval(() => {
      if (Math.random() > 0.85) createSubtleFlash();
    }, 8000);

    // Hover: reset lightning animation on cards
    const cards = document.querySelectorAll('#cc-sections-wrapper .cc-section-card');
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        const bolts = card.querySelectorAll('.cc-bolt-white');
        bolts.forEach(bolt => {
          const oldAnim = bolt.style.animation;
          bolt.style.animation = 'none';
          setTimeout(() => { bolt.style.animation = oldAnim || 'cc-lightningFlash 1.8s infinite ease-in-out'; }, 10);
        });
      });
    });

    // 3D icon hover effect
    const icons = document.querySelectorAll('#cc-sections-wrapper .cc-icon-3d');
    icons.forEach(icon => {
      icon.addEventListener('mouseenter', function() {
        this.style.transform = 'translateY(-5px) rotateX(10deg) scale(1.08)';
      });
      icon.addEventListener('mouseleave', function() {
        this.style.transform = '';
      });
    });
  })();
</script>

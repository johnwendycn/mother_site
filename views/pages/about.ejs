<script>
    (function() {
        // Modal elements
        var modal = document.getElementById('vr-video-modal');
        var playBtn = document.querySelector('#rs-video-advanced .popup-vimeo');
        var closeBtn = document.querySelector('.vr-modal-close');
        var iframe = document.getElementById('vimeo-player');
        var originalSrc = iframe ? iframe.src : '';

        // Open modal
        function openModal() {
            if (modal) {
                modal.classList.add('show');
                document.body.style.overflow = 'hidden';
                
                // Add video ID with autoplay
                if (iframe) {
                    iframe.src = 'https://player.vimeo.com/video/863884866?autoplay=1&title=0&byline=0&portrait=0&badge=0';
                }
            }
        }

        // Close modal
        function closeModal() {
            if (modal) {
                modal.classList.remove('show');
                document.body.style.overflow = '';
                
                // Stop video when closing
                if (iframe) {
                    iframe.src = originalSrc;
                }
            }
        }

        // Event listeners
        if (playBtn) {
            playBtn.addEventListener('click', function(e) {
                e.preventDefault();
                openModal();
            });
        }

        if (closeBtn) {
            closeBtn.addEventListener('click', closeModal);
        }

        // Close on overlay click
        window.addEventListener('click', function(event) {
            if (modal && modal.classList.contains('show')) {
                if (event.target === modal || event.target.classList.contains('vr-modal-overlay')) {
                    closeModal();
                }
            }
        });

        // Close on ESC
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape' && modal && modal.classList.contains('show')) {
                closeModal();
            }
        });

        // Lightning bolt randomizer
        var bolts = document.querySelectorAll('#rs-video-advanced .lightning-bolt');
        function randomizeBolts() {
            bolts.forEach(function(bolt) {
                var randomDur = (Math.random() * 2 + 1).toFixed(2);
                bolt.style.animationDuration = randomDur + 's';
            });
        }
        if (bolts.length) {
            setInterval(randomizeBolts, 4000);
            randomizeBolts();
        }
    })();
</script>
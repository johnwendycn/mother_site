<style>
    /* Investment Page Styles - Professional Edition */
    .rs-investment {
        position: relative;
        padding: 80px 0;
        background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
    }

    /* Doves Animation */
    .doves-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 999;
        overflow: hidden;
    }
    .dove {
        position: absolute;
        font-size: 28px;
        color: rgba(220, 0, 40, 0.15);
        animation: flyDove 12s ease-in-out infinite;
        opacity: 0;
    }
    .dove i {
        display: block;
    }
    .dove1 { top: 10%; left: -50px; animation-delay: 0s; }
    .dove2 { top: 25%; left: -50px; animation-delay: 2.5s; font-size: 22px; }
    .dove3 { top: 45%; left: -50px; animation-delay: 5s; font-size: 34px; }
    .dove4 { top: 65%; left: -50px; animation-delay: 7.5s; font-size: 20px; }
    .dove5 { top: 80%; left: -50px; animation-delay: 3s; font-size: 26px; }
    .dove6 { top: 15%; left: -50px; animation-delay: 4.5s; font-size: 18px; }
    .dove7 { top: 55%; left: -50px; animation-delay: 6.5s; font-size: 30px; }
    .dove8 { top: 75%; left: -50px; animation-delay: 1.5s; font-size: 24px; }
    @keyframes flyDove {
        0% { left: -50px; opacity: 0; transform: translateY(0) rotate(0deg); }
        10% { opacity: 0.6; }
        30% { opacity: 0.8; }
        70% { opacity: 0.8; }
        90% { opacity: 0.4; }
        100% { left: 110%; opacity: 0; transform: translateY(-60px) rotate(8deg); }
    }


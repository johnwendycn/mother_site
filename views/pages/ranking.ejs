<style>
    /* Ranking Page Styles */
    .rs-ranking {
        position: relative;
        padding: 80px 0;
        background: linear-gradient(135deg, #f5f5f5 0%, #ffffff 100%);
        overflow-x: hidden;
    }

    .rs-ranking::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at 20% 40%, rgba(220, 0, 40, 0.03) 0%, transparent 50%);
        pointer-events: none;
    }

    /* Train Animation */
    .train-container {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 100px;
        pointer-events: none;
        z-index: 100;
        overflow: hidden;
    }
    .train {
        position: absolute;
        bottom: 0;
        left: -200px;
        display: flex;
        animation: trainMove 12s linear infinite;
    }
    .train-engine {
        background: linear-gradient(135deg, #2c3e50, #1a1a2e);
        padding: 12px 20px;
        border-radius: 10px 10px 0 0;
        color: #ffeb3b;
        font-size: 28px;
    }
    .train-smoke {
        position: absolute;
        top: -20px;
        left: 10px;
        width: 25px;
        height: 25px;
        background: rgba(200,200,200,0.6);
        border-radius: 50%;
        animation: smokePuff 0.8s ease-out infinite;
    }
    .train-coach {
        background: #34495e;
        padding: 12px 25px;
        border-radius: 10px 10px 0 0;
        margin-left: 5px;
        color: #ffeb3b;
        font-weight: bold;
    }
    @keyframes trainMove { 0% { left: -300px; } 100% { left: 100%; } }
    @keyframes smokePuff { 0% { opacity: 0.6; transform: translateY(0) scale(1); } 100% { opacity: 0; transform: translateY(-40px) scale(2); } }

    /* Doves Animation */
    .doves-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 99;
        overflow: hidden;
    }
    .dove {
        position: absolute;
        font-size: 28px;
        color: rgba(220, 0, 40, 0.3);
        animation: flyDove 8s ease-in-out infinite;
    }
    .dove1 { top: 10%; left: -50px; animation-delay: 0s; }
    .dove2 { top: 30%; left: -50px; animation-delay: 2s; font-size: 22px; }
    .dove3 { top: 50%; left: -50px; animation-delay: 4s; font-size: 32px; }
    .dove4 { top: 70%; left: -50px; animation-delay: 6s; font-size: 20px; }
    .dove5 { top: 85%; left: -50px; animation-delay: 3s; font-size: 26px; }
    @keyframes flyDove {
        0% { left: -50px; opacity: 0; transform: translateY(0) rotate(0deg); }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { left: 110%; opacity: 0; transform: translateY(-80px) rotate(10deg); }
    }

    /* Title Section */
    .ranking-title {
        margin-bottom: 40px;
        position: relative;
        z-index: 5;
    }
    .main-title {
        font-size: 38px;
        font-weight: 800;
        color: #DC0028;
        text-transform: uppercase;
        letter-spacing: 2px;
        display: inline-block;
        padding-bottom: 15px;
        position: relative;
    }
    .main-title::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(90deg, #ffeb3b, #DC0028, #ffeb3b);
        animation: underlineShimmer 2s linear infinite;
        background-size: 200% 100%;
    }
    .lightning-icon { color: #ffeb3b; animation: lightningPulse 0.5s ease infinite; margin-right: 15px; }
    .cloud-icon { color: #bdc3c7; animation: cloudFloat 4s ease-in-out infinite; margin-left: 15px; }
    .subtitle { font-size: 18px; color: #666; margin-top: 15px; }
    @keyframes lightningPulse { 0%,100% { opacity:1; transform:scale(1); text-shadow:0 0 5px #ffeb3b; } 50% { opacity:0.7; transform:scale(1.15); text-shadow:0 0 20px #ffeb3b; } }
    @keyframes cloudFloat { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-5px); } }
    @keyframes underlineShimmer { 0% { background-position:0% 50%; } 100% { background-position:200% 50%; } }

    /* Banner */
    .ranking-banner {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        margin-bottom: 50px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    }
    .banner-image {
